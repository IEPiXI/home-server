# ip of the server running home assistant (e.g. 192.168.1.50)
HOME_ASSISTANT_SERVER_IP=192.168.x.x

# long-lived access token from home assistant user profile
HOME_ASSISTANT_TOKEN=your_token_here

# url path to your custom home assistant dashboard (e.g. home-server, energy)
HOME_ASSISTANT_DASHBOARD_PATH=home-server

# entity ids for your shelly plug sensors
HOME_ASSISTANT_SHELLY_POWER=sensor.shelly_homeserver_leistung
HOME_ASSISTANT_SHELLY_ENERGY=sensor.shelly_homeserver_energie
HOME_ASSISTANT_SHELLY_VOLTAGE=sensor.shellyplugmg3_089272515bc4_spannung
HOME_ASSISTANT_SHELLY_CURRENT=sensor.shellyplugmg3_089272515bc4_stromstarke
